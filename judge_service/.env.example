LLM_PROVIDER=openrouter

# OpenRouter backend
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama backend (used only when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2:7b-instruct-q4_K_M

# Shared Postgres with dialogue_sessions / dialogue_messages / judge_results
DATABASE_URL=postgresql://dialogue:dialogue@localhost:5432/dialogues
